              "github.com/codemityio/goforma/pkg/code/gen" -> "github.com/codemityio/goforma/pkg/code/imports"
              "github.com/codemityio/goforma/pkg/code/gen" -> "github.com/codemityio/goforma/pkg/code/parser"
        "github.com/codemityio/goforma/pkg/code/imports" [label="github.com/codemityio/goforma/pkg/code/imports", color="gray58", fillcolor="gray99", penwidth=1]
              "github.com/codemityio/goforma/pkg/code/imports" -> "golang.org/x/tools/go/packages"
        "github.com/codemityio/goforma/pkg/code/parser" [label="github.com/codemityio/goforma/pkg/code/parser", color="gray58", fillcolor="gray99", penwidth=1]
              "github.com/codemityio/goforma/pkg/code/parser" -> "github.com/codemityio/goforma/pkg/code/doc"
              "github.com/codemityio/goforma/pkg/code/parser" -> "golang.org/x/tools/go/packages"
        "golang.org/x/sync/errgroup" [label="golang.org/x/sync/errgroup", color="gray65", fillcolor="gray83", penwidth=1]
        "golang.org/x/tools/go/gcexportdata" [label="golang.org/x/tools/go/gcexportdata", color="gray65", fillcolor="gray83", penwidth=1]
        "golang.org/x/tools/go/packages" [label="golang.org/x/tools/go/packages", color="gray65", fillcolor="gray83", penwidth=1]
              "golang.org/x/tools/go/packages" -> "golang.org/x/sync/errgroup"
              "golang.org/x/tools/go/packages" -> "golang.org/x/tools/go/gcexportdata"
    }
